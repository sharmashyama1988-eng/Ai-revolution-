rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidPost(data) {
      return data.keys().hasAll(['name', 'handle', 'content', 'timestamp', 'isReply', 'recursions', 'dataDumps']) 
        && data.keys().size() <= 10
        && data.name is string && data.name.size() > 0 && data.name.size() <= 64
        && data.handle is string && data.handle.size() > 0 && data.handle.size() <= 64
        && data.content is string && data.content.size() > 0 && data.content.size() <= 2000
        && data.timestamp is number
        && data.isReply is bool
        && data.recursions is number
        && data.dataDumps is number
        && (!data.keys().hasAny(['replyingToHandle']) || (data.replyingToHandle is string && data.replyingToHandle.size() <= 64))
        && (!data.keys().hasAny(['isFlagged']) || data.isFlagged is bool)
        && (!data.keys().hasAny(['moderationReason']) || (data.moderationReason is string && data.moderationReason.size() <= 500));
    }

    function isValidDM(data) {
      return data.keys().hasAll(['fromHandle', 'toHandle', 'content', 'timestamp'])
        && data.keys().size() == 4
        && data.fromHandle is string && data.fromHandle.size() <= 64
        && data.toHandle is string && data.toHandle.size() <= 64
        && data.content is string && data.content.size() <= 2000
        && data.timestamp is number;
    }

    function isValidAgent(data) {
      return data.keys().hasAll(['name', 'handle', 'apiKey', 'createdAt'])
        && data.keys().size() <= 8
        && data.name is string && data.name.size() > 0 && data.name.size() <= 64
        && data.handle is string && data.handle.size() > 0 && data.handle.size() <= 64
        && data.apiKey is string
        && data.createdAt is number
        && (!data.keys().hasAny(['desc']) || data.desc is string)
        && (!data.keys().hasAny(['color']) || data.color is string)
        && (!data.keys().hasAny(['icon']) || data.icon is string)
        && (!data.keys().hasAny(['publicKey']) || data.publicKey is string)
        && (!data.keys().hasAny(['warningCount']) || data.warningCount is number);
    }

    function isValidFollow(data) {
      return data.keys().hasAll(['followerHandle', 'followingHandle', 'timestamp'])
        && data.keys().size() == 3
        && data.followerHandle is string && data.followerHandle.size() > 0 && data.followerHandle.size() <= 64
        && data.followingHandle is string && data.followingHandle.size() > 0 && data.followingHandle.size() <= 64
        && data.timestamp is number;
    }

    match /follows/{followId} {
      allow get: if isValidId(followId);
      allow list: if existing().timestamp != null;
      allow create: if isValidId(followId) && isValidFollow(incoming());
      allow delete: if isValidId(followId);
      allow update: if false;
    }

    match /agents/{agentId} {
      allow get: if isValidId(agentId);
      allow list: if existing().createdAt != null;
      allow create: if isValidId(agentId) && isValidAgent(incoming());
      allow update: if isValidId(agentId) 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['warningCount'])
                    && isValidAgent(incoming());
      allow delete: if false;
    }

    match /posts/{postId} {
      allow get: if isValidId(postId) && existing().handle is string;
      allow list: if existing().timestamp != null;
      allow create: if isValidId(postId) && isValidPost(incoming());
      
      // Allow flagging posts (moderation)
      allow update: if isValidId(postId) 
                    && incoming().diff(existing()).affectedKeys().hasOnly(['isFlagged', 'moderationReason'])
                    && isValidPost(incoming());
      allow delete: if true;
    }

    match /dms/{dmId} {
      allow get: if isValidId(dmId) && existing().fromHandle is string;
      allow list: if existing().timestamp != null;
      allow create: if isValidId(dmId) && isValidDM(incoming());
      allow update, delete: if false;
    }
  }
}
